# Gmail 发件账号
GMAIL_USER=your_gmail@gmail.com

# Gmail 应用专用密码（不是登录密码）
# 获取方式：Google 账号 → 安全 → 两步验证 → 应用专用密码
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# BCC 收件人（分号分隔）
BCC_TO=editor1@example.com;editor2@example.com

# 可选配置
# MAX_PAGES=50          # PDF 最大分析页数（默认 50）
# LLM_TIMEOUT=600       # Claude CLI 单次调用超时秒数（默认 600）
# MAX_TEXT_LENGTH=80000 # 每次 Agent 调用的最大字符数（默认 80000）
# ENABLE_SCHOLAR=1      # 启用 Google Scholar 引文搜索（默认关闭，易被反爬虫阻断）
