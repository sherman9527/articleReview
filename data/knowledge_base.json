{
  "version": "1.0.0",
  "description": "AI审稿系统知识库 — 综合《编辑必备语词规范手册》《图书编辑校对实用手册》《图书编校质量差错案例》整理",
  "sources": [
    "编辑必备语词规范手册（利来友，广西师范大学出版社，2019）",
    "图书编辑校对实用手册 第五版（黎洪波、利来友）",
    "图书编校质量差错案例（中央宣传部出版产品质量监督检测中心）"
  ],
  "yixingci": {
    "description": "异形词整理表（第一批，国家语言文字工作委员会2001年发布，共338组）",
    "principle": "从三个原则选择规范形式：通用性原则（使用频率最高）、理据性原则（字形来源合理）、系统性原则（形旁声旁一致）",
    "common_pairs": [
      {"wrong": "按纳", "correct": "按捺", "note": "按捺不住、按捺性子"},
      {"wrong": "班白", "correct": "斑白", "note": "斑白的鬓发"},
      {"wrong": "颁白", "correct": "斑白", "note": "斑白的鬓发"},
      {"wrong": "必恭必敬", "correct": "毕恭毕敬", "note": "毕恭毕敬地行礼"},
      {"wrong": "布署", "correct": "部署", "note": "部署任务、战略部署"},
      {"wrong": "份量", "correct": "分量", "note": "分量十足"},
      {"wrong": "尝试", "correct": null, "note": "尝试为正确形式（尝=品味、试用）"},
      {"wrong": "掺和", "correct": null, "note": "掺和（混合）与搀和（扶持）意义不同，需区别"},
      {"wrong": "急燥", "correct": "急躁", "note": "急躁、浮躁（均用躁）"},
      {"wrong": "浮燥", "correct": "浮躁", "note": "急躁、浮躁（均用躁）"},
      {"wrong": "其它", "correct": "其他", "note": "其他为规范形式"},
      {"wrong": "哟", "correct": null, "note": "哟与喲均可，哟为推荐形式"},
      {"wrong": "叫嚣", "correct": null, "note": "叫嚣为规范形式（非叫嚣）"},
      {"wrong": "联接", "correct": "连接", "note": "连接、链接（不用联接）"},
      {"wrong": "磨练", "correct": "磨炼", "note": "磨炼意志（炼字）"},
      {"wrong": "那末", "correct": "那么", "note": "那么为规范形式"},
      {"wrong": "这末", "correct": "这么", "note": "这么为规范形式"},
      {"wrong": "朴实", "correct": null, "note": "朴实为规范形式（朴素朴实）"},
      {"wrong": "气慨", "correct": "气概", "note": "气概为规范形式"},
      {"wrong": "凄凉", "correct": null, "note": "凄凉为规范形式"},
      {"wrong": "前仆后继", "correct": null, "note": "前仆后继为规范形式（仆=向前倒）"},
      {"wrong": "前赴后继", "correct": "前仆后继", "note": "赴字有误，应为仆"},
      {"wrong": "沈思", "correct": "沉思", "note": "沈仅用于人名、地名"},
      {"wrong": "受益匪浅", "correct": null, "note": "受益匪浅为规范形式"},
      {"wrong": "踊跃", "correct": null, "note": "踊跃为规范形式（非勇跃）"},
      {"wrong": "勇跃", "correct": "踊跃", "note": "踊跃为规范形式"},
      {"wrong": "装祯", "correct": "装帧", "note": "装帧设计（帧字）"},
      {"wrong": "座右铭", "correct": null, "note": "座右铭为规范形式"},
      {"wrong": "坐右铭", "correct": "座右铭", "note": "座右铭（座位的座）"},
      {"wrong": "挖墙角", "replacement": "挖墙脚", "note": "挖墙脚为规范形式"},
      {"wrong": "精萃", "correct": "精粹", "note": "精粹（粹字，纯粹）"},
      {"wrong": "神彩", "correct": "神采", "note": "神采奕奕（采字）"},
      {"wrong": "渲泄", "correct": "宣泄", "note": "宣泄情绪（宣字）"},
      {"wrong": "宣泻", "correct": "宣泄", "note": "宣泄情绪（泄字）"},
      {"wrong": "蛰伏", "correct": null, "note": "蛰伏为规范形式（蛰=冬眠）"},
      {"wrong": "蜇伏", "correct": "蛰伏", "note": "蜇=蜂蜇，蛰=冬眠，意义不同"},
      {"wrong": "再接再励", "correct": "再接再厉", "note": "再接再厉（厉=磨砺）"},
      {"wrong": "草管人命", "correct": "草菅人命", "note": "草菅（菅=茅草名）"},
      {"wrong": "烂竽充数", "correct": "滥竽充数", "note": "滥竽充数（滥字）"},
      {"wrong": "貌和神离", "correct": "貌合神离", "note": "貌合神离（合字）"},
      {"wrong": "一诺千斤", "correct": "一诺千金", "note": "一诺千金（金字）"},
      {"wrong": "义不容词", "correct": "义不容辞", "note": "义不容辞（辞字）"}
    ]
  },
  "prohibited_terms": {
    "description": "官方明令禁止或要求更正的词语",
    "items": [
      {"term": "满清", "required": "清朝/清代", "source": "国务院规定", "reason": "满清有歧视含义，应使用朝代名"},
      {"term": "蒙古大夫", "required": "（禁用）", "source": "出版规定", "reason": "歧视少数民族（蒙古族）"},
      {"term": "支那", "required": "中国", "source": "抗战史规范", "reason": "日本侵华时期歧视性称谓"},
      {"term": "八年抗战", "required": "十四年抗战", "source": "教育部2017年通知", "reason": "抗战起始于1931年九一八事变，非1937年"},
      {"term": "汉城", "required": "首尔", "source": "2005年韩国政府更名", "reason": "韩国首都已于2005年正式更名"},
      {"term": "喇嘛教", "required": "藏传佛教", "source": "民族宗教政策", "reason": "藏传佛教的规范称谓"}
    ]
  },
  "taiwan_hk_language": {
    "description": "涉台涉港涉澳表述规范",
    "rules": [
      {"rule": "台湾地区与台湾", "detail": "在官方文件中一般使用"台湾地区"而非"台湾省"（台湾省政府1998年精简）"},
      {"rule": "香港表述", "detail": "1997年前称"香港英占时期"，不称"殖民地时期""},
      {"rule": "澳门表述", "detail": "1999年前称"葡占时期"，不称"殖民地时期""},
      {"rule": "避免使用", "detail": "沦陷台湾、收复台湾、光复台湾（含立场倾向的词汇）"},
      {"rule": "钓鱼岛", "detail": "中国大陆标准名称，不用"钓鱼台"（台湾用法）"}
    ]
  },
  "number_standards": {
    "description": "数字用法规范（GB/T 15835-2011）",
    "rules": [
      {"rule": "阿拉伯数字", "detail": "公历世纪、年代、年月日、时刻、各种统计数字均用阿拉伯数字"},
      {"rule": "汉字数字", "detail": "非公历纪年（如农历、朝代年号）、概数（约、余、多、几）用汉字"},
      {"rule": "21世纪", "detail": "公历世纪用阿拉伯数字：21世纪（非"二十一世纪"）"},
      {"rule": "年份", "detail": "年份用阿拉伯数字：2024年（非"二〇二四年"，除非特别行文需要）"},
      {"rule": "分数", "detail": "分数用阿拉伯数字：3/4（非"四分之三"，除行文特别需要）"},
      {"rule": "百分数", "detail": "百分数用阿拉伯数字加%：75%（非"百分之七十五"）"},
      {"rule": "相邻概数", "detail": "相邻两个数字表示的概数之间不加顿号：三四天、五六个（非"三、四天"）"},
      {"rule": "数字超四位", "detail": "整数超过四位时，用空格分节：1 000 000（非1,000,000）"}
    ]
  },
  "citation_standards": {
    "description": "引文格式规范（GB/T 7714-2015）",
    "format_types": {
      "M": {"name": "专著", "template": "作者. 书名[M]. 版次（初版不标注）. 出版地: 出版社, 年份: 起止页码."},
      "J": {"name": "期刊论文", "template": "作者. 题名[J]. 刊名, 年份, 卷(期): 起止页码."},
      "D": {"name": "学位论文", "template": "作者. 题名[D]. 学校所在地: 学校, 年份."},
      "N": {"name": "报纸", "template": "作者. 题名[N]. 报纸名, 出版日期(版次)."},
      "C": {"name": "会议论文", "template": "作者. 题名[C]//论文集主编. 论文集名. 出版地: 出版社, 年份: 起止页码."},
      "EB_OL": {"name": "网络资源", "template": "作者. 题名[EB/OL]. URL, 发布日期[引用日期]."},
      "R": {"name": "报告", "template": "作者. 报告名[R]. 出版地: 单位名称, 年份."}
    },
    "common_issues": [
      "作者超过3人时，列出前3位后加"等"或"et al."",
      "中文文献作者姓名不加逗号（如"张三李四"），外文文献姓在前名在后（"Smith J"）",
      "书名用书名号《》，勿用引号",
      "文献类型标识符必须有（[M][J][D]等）",
      "起止页码用连字号或破折号连接（如"125-136"或"125—136"）",
      "电子文献必须注明访问日期"
    ]
  },
  "punctuation_rules": {
    "description": "标点符号规范（GB/T 15834-2011）",
    "rules": [
      {"mark": "书名号《》", "usage": "书名、篇名、刊名、影片名等，不能用引号代替"},
      {"mark": "引号""''", "usage": "外层用""，内层用''；直接引语用引号，间接引语不用"},
      {"mark": "省略号……", "usage": "六个圆点，只用汉字省略号，不用英文三点(...)"},
      {"mark": "破折号——", "usage": "两个连字符，不用单破折号（—）"},
      {"mark": "顿号、", "usage": "并列词语之间；相邻概数之间不加顿号（三四天、五六个）"},
      {"mark": "括号（）", "usage": "行内括注用（），独立补充说明置于句号外"},
      {"mark": "冒号：", "usage": "引起下文；总结上文；提示性话语之后"}
    ]
  },
  "academic_writing_standards": {
    "description": "学术写作规范",
    "rules": [
      {"rule": "来源注明", "detail": "所有观点引用必须注明来源，不允许"有研究表明"等无来源断言"},
      {"rule": "数据来源", "detail": "所有统计数字、图表数据必须注明来源"},
      {"rule": "直接引用", "detail": "直接引用须加引号，超过三行另起段落并缩进"},
      {"rule": "转引", "detail": "转引时需注明"转引自"及原始出处"},
      {"rule": "AI内容", "detail": "使用AI生成内容须声明，并验证其准确性"},
      {"rule": "图表", "detail": "图表必须有编号（图1）、标题和来源说明"},
      {"rule": "首次缩写", "detail": "首次出现的缩略词/字母词应给出中文全称（如"WHO（世界卫生组织）"）"}
    ]
  },
  "style_guidelines": {
    "description": "文风与表达规范",
    "avoid": [
      "众所周知、毫无疑问、不言而喻（断言套话，学术写作应有论据）",
      "笔者认为、个人认为（口语化，影响客观性）",
      "如前所述（频繁使用时可能是重复叙述）",
      "等等（出版物中应穷举或说明省略依据）",
      "大约、大概（学术写作应使用精确数字或注明范围）",
      "口语化词汇（如"老外""挺好""很厉害"）"
    ],
    "special_phrases": [
      {"phrase": "差强人意", "correct_meaning": "勉强令人满意", "common_mistake": "常被误解为不满意"},
      {"phrase": "望其项背", "correct_meaning": "赶上（只用于否定：难以望其项背）", "common_mistake": "正面使用"},
      {"phrase": "首当其冲", "correct_meaning": "首先受到冲击（贬义）", "common_mistake": "误用为褒义"},
      {"phrase": "空穴来风", "correct_meaning": "有根据（原义）", "common_mistake": "误用为无中生有"},
      {"phrase": "炙手可热", "correct_meaning": "权势显赫，令人难以接近（贬义）", "common_mistake": "误用于形容物品流行"},
      {"phrase": "不以为然", "correct_meaning": "不认为是正确的", "common_mistake": "误解为不在乎"},
      {"phrase": "目无全牛", "correct_meaning": "技艺纯熟（褒义）", "common_mistake": "误作贬义"},
      {"phrase": "凤毛麟角", "correct_meaning": "珍贵稀少（褒义）", "common_mistake": "用于贬义语境"},
      {"phrase": "噤若寒蝉", "correct_meaning": "因恐惧不敢发声", "common_mistake": "与保持沉默混淆"},
      {"phrase": "七月流火", "correct_meaning": "指天气转凉（非炎热）", "common_mistake": "误用为形容炎热"}
    ]
  },
  "quality_inspection_standards": {
    "description": "图书质量检测标准（中宣部出版产品质量监督检测中心标准）",
    "error_classification": {
      "差错率": "每万字差错不超过1个为合格（学术书籍）",
      "一般差错": "错别字、标点错误、数字用法错误等",
      "严重差错": "政治性错误、常识性错误、知识性错误等，每个计3个差错",
      "特别严重": "违反宪法、损害国家尊严、破坏民族团结等，直接判定不合格"
    },
    "inspection_scope": [
      "封面、书脊、版权页",
      "目录与正文一致性",
      "正文编辑规范性",
      "插图、表格、公式规范性",
      "参考文献格式规范性",
      "索引准确性（如有）"
    ]
  }
}
